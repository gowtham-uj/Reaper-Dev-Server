.env
.env.*
!.env.example
.envrc
*.env.local

# Docker Compose / pod env files
docker-compose.override.yml
docker-compose.local.yml
.env.docker

# SSH / TLS / signing material
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.keystore
*.jks
.reaper-ssh-password*
reaper-ssh-password*
.ssh/

# Reaper session / runtime secrets
**/reaper-ssh-password*
**/*.reaper-ssh-password

# Reaper local control-plane state
.reaper-local/
backend/.reaper-local/
backend-state/
backend-state/**
